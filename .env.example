# AwdUI MCP — optional environment overrides
# Copy to .env in the repo root (never commit .env).

# --- Auto-update (see docs/AGENTS_AUTOUPDATE.md) ---
# Check GitHub Releases on startup / get_server_info
AWDUI_UPDATE_CHECK=true

# Apply release zip before starting MCP (requires scripts/launcher.py in plugin.json)
AWDUI_AUTO_UPDATE=true

# Skip background version notification on MCP startup
# AWDUI_SKIP_VERSION_CHECK=true

# GitHub repo for releases (default: aostapow/AwdUI-MCP)
# AWDUI_GITHUB_REPO=aostapow/AwdUI-MCP

# Mirror / alternate releases API URL
# AWDUI_UPDATE_URL=https://api.github.com/repos/aostapow/AwdUI-MCP/releases/latest

# Version check cache interval in seconds (default: 86400)
# AWDUI_VERSION_CHECK_INTERVAL=86400

# Focus-window cache TTL in seconds (default: 3.0)
# AWDUI_FOCUS_TTL=3.0

# Restore pre-click screenshot diff on click/scroll (slower)
# AWDUI_VERIFY=1

# Full object snapshots on smart_find remember
# AWDUI_SNAPSHOT=1
